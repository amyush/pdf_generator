<!DOCTYPE html>
<html>
<head>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: 'Segoe UI', Arial, sans-serif; font-size: 11px; color: #333; padding: 10px; }
  .header { display: flex; justify-content: space-between; border-bottom: 3px solid #1a5276; padding-bottom: 12px; margin-bottom: 15px; }
  .company-name { font-size: 20px; font-weight: bold; color: #1a5276; }
  .company-details { font-size: 9px; color: #666; margin-top: 4px; line-height: 1.5; }
  .doc-info { text-align: right; }
  .doc-label { font-size: 9px; color: #888; text-transform: uppercase; }
  .doc-number { font-size: 16px; font-weight: bold; color: #1a5276; }
  .doc-date { font-size: 10px; margin-top: 2px; }
  .title { text-align: center; font-size: 14px; font-weight: bold; color: #1a5276; text-transform: uppercase; letter-spacing: 2px; margin: 10px 0; }
  .info-grid { display: flex; gap: 12px; margin-bottom: 15px; }
  .info-box { flex: 1; border: 1px solid #ddd; border-radius: 4px; padding: 8px; }
  .info-box h4 { font-size: 9px; text-transform: uppercase; color: #1a5276; border-bottom: 1px solid #eee; padding-bottom: 4px; margin-bottom: 6px; letter-spacing: 1px; }
  .info-box p { font-size: 10px; line-height: 1.6; }
  table { width: 100%; border-collapse: collapse; margin: 10px 0; }
  th { background: #1a5276; color: #fff; padding: 6px 5px; text-align: left; font-size: 9px; text-transform: uppercase; letter-spacing: 0.5px; }
  td { padding: 5px; border-bottom: 1px solid #eee; font-size: 10px; }
  tr:nth-child(even) { background: #f8f9fa; }
  .text-right { text-align: right; }
  .totals { margin-left: auto; width: 260px; margin-top: 10px; }
  .totals-row { display: flex; justify-content: space-between; padding: 3px 0; font-size: 10px; }
  .totals-row.grand { border-top: 2px solid #1a5276; font-weight: bold; font-size: 13px; color: #1a5276; padding-top: 6px; margin-top: 4px; }
  .terms { margin-top: 25px; }
  .terms h4 { font-size: 10px; color: #1a5276; margin-bottom: 4px; }
  .terms p { font-size: 9px; color: #666; line-height: 1.5; }
  .signatures { display: flex; justify-content: space-between; margin-top: 50px; }
  .sig-box { text-align: center; width: 180px; }
  .sig-line { border-top: 1px solid #333; padding-top: 4px; font-size: 9px; color: #666; }
  .page-info { text-align: center; font-size: 8px; color: #999; margin-top: 10px; }
</style>
</head>
<body>

{{#if showHeader}}
<div class="header">
  <div>
    <div class="company-name">{{company.name}}</div>
    <div class="company-details">
      {{company.address}}<br>
      GSTIN: {{company.gstin}} | PAN: {{company.pan}}<br>
      {{company.phone}} | {{company.email}}
    </div>
  </div>
  <div class="doc-info">
    <div class="doc-label">Purchase Order</div>
    <div class="doc-number">{{poNumber}}</div>
    <div class="doc-date">Date: {{formatDate date}}</div>
    <div class="doc-date">Delivery: {{formatDate deliveryDate}}</div>
  </div>
</div>

<div class="title">Purchase Order</div>

<div class="info-grid">
  <div class="info-box">
    <h4>Vendor</h4>
    <p>
      <strong>{{vendor.name}}</strong><br>
      {{vendor.address}}<br>
      GSTIN: {{vendor.gstin}}<br>
      Contact: {{vendor.contact}}
    </p>
  </div>
  <div class="info-box">
    <h4>Ship To</h4>
    <p>
      <strong>{{shipTo.name}}</strong><br>
      {{shipTo.address}}<br>
      Contact: {{shipTo.contact}}
    </p>
  </div>
</div>
{{/if}}

<table>
  <thead>
    <tr>
      <th style="width:4%">#</th>
      <th style="width:32%">Description</th>
      <th style="width:10%">HSN</th>
      <th style="width:8%">Qty</th>
      <th style="width:6%">Unit</th>
      <th style="width:14%" class="text-right">Rate</th>
      <th style="width:8%" class="text-right">Tax%</th>
      <th style="width:16%" class="text-right">Amount</th>
    </tr>
  </thead>
  <tbody>
    {{#each items}}
    <tr>
      <td>{{rowIndex @index}}</td>
      <td>{{this.description}}</td>
      <td>{{this.hsn}}</td>
      <td>{{this.quantity}}</td>
      <td>{{this.unit}}</td>
      <td class="text-right">{{currency this.rate}}</td>
      <td class="text-right">{{this.taxPercent}}%</td>
      <td class="text-right">{{currency this.amount}}</td>
    </tr>
    {{/each}}
  </tbody>
</table>

{{#if showSummary}}
<div class="totals">
  <div class="totals-row"><span>Subtotal:</span><span>{{currency subtotal}}</span></div>
  <div class="totals-row"><span>CGST ({{cgstPercent}}%):</span><span>{{currency cgst}}</span></div>
  <div class="totals-row"><span>SGST ({{sgstPercent}}%):</span><span>{{currency sgst}}</span></div>
  <div class="totals-row grand"><span>Grand Total:</span><span>{{currency total}}</span></div>
</div>

<div class="terms">
  <h4>Terms & Conditions</h4>
  {{#each terms}}
  <p>{{rowIndex @index}}. {{this}}</p>
  {{/each}}
</div>

<div class="signatures">
  <div class="sig-box"><div class="sig-line">Prepared By</div></div>
  <div class="sig-box"><div class="sig-line">Authorized Signatory</div></div>
</div>
{{/if}}

{{#if pageInfo}}
<div class="page-info">Page {{pageInfo.current}} of {{pageInfo.total}}</div>
{{/if}}

</body>
</html>
